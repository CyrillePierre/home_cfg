diff --git a/src/terminal/osc/parsers/cfy.zig b/src/terminal/osc/parsers/cfy.zig
new file mode 100644
index 0000000..682f3fd
--- /dev/null
+++ b/src/terminal/osc/parsers/cfy.zig
@@ -0,0 +1,57 @@
+const std = @import("std");
+
+const Parser = @import("../../osc.zig").Parser;
+const Command = @import("../../osc.zig").Command;
+
+/// Parse OSC 4273
+pub fn parse(parser: *Parser, _: ?u8) ?*Command {
+    const writer = parser.writer orelse {
+        parser.state = .invalid;
+        return null;
+    };
+
+    cfy: {
+        writer.writeByte(0) catch {
+            parser.state = .invalid;
+            return null;
+        };
+
+        var data = writer.buffered();
+        if (data.len == 0) break :cfy;
+        switch (data[0]) {
+            // Check for OSC 9;1 9;10 9;11 9;12
+            '1' => {
+                if (data.len < 2) break :cfy;
+                switch (data[1]) {
+                    // OSC 4273;1 set rect
+                    ';' => {
+                        parser.command = .{
+                            .cfy = .{
+                                .value = data[2 .. data.len - 1 :0],
+                            },
+                        };
+                        return &parser.command;
+                    },
+                    else => break :cfy,
+                }
+            },
+            else => break :cfy,
+        }
+    }
+
+    parser.state = .invalid;
+    return null;
+}
+
+test "OSC 4273;1: set rect" {
+    const testing = std.testing;
+
+    var p: Parser = .init(null);
+
+    const input = "4273;1;5,6,40,41";
+    for (input) |ch| p.next(ch);
+
+    const cmd = p.end('\x1b').?.*;
+    try testing.expect(cmd == .cfy);
+    try testing.expectEqualStrings("5,6,40,41", cmd.cfy.value);
+}
