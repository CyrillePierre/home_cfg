         self.surfaceMessageWriter(.{ .progress_report = report });
     }
+
+    fn setCfyRect(self: *StreamHandler, arg: terminal.osc.Command.CfySetRect) void {
+        var parts = std.mem.splitAny(u8, arg.value, ",");
+        var i: usize = 0;
+        var cfy_rect: [4]f32 = .{-1.0, -1.0, -1.0, -1.0};
+
+        while (parts.next()) |part| {
+            if (i >= cfy_rect.len) break;
+            const val = std.fmt.parseFloat(f32, part) catch -1.0;
+            cfy_rect[i] = val;
+            i += 1;
+        }
+
+        self.rendererMessageWriter(.{ .set_cfy_rect = cfy_rect });
+    }
 };
