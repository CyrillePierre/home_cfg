+        pub fn setCfyRect(self: *Self, rect: [4]f32) void {
+            const screen_width: f32 = @floatFromInt(self.size.screen.width);
+            const screen_height: f32 = @floatFromInt(self.size.screen.height);
+            const cell_width: f32 = @floatFromInt(self.size.cell.width);
+            const cell_height: f32 = @floatFromInt(self.size.cell.height);
+
+            self.cfy_rect = .{
+                if (rect[0] < 0) screen_width else rect[0] * cell_width,
+                if (rect[1] < 0) screen_height else screen_height - rect[1] * cell_height,
+                if (rect[2] < 0) screen_width else rect[2] * cell_width,
+                if (rect[3] < 0) screen_height else rect[3] * cell_height,
+            };
+        }
+
         /// Update uniforms that are based on the font grid.
         ///
         /// Caller must hold the draw mutex.
